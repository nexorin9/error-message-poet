# OpenAI API Key
OPENAI_API_KEY=your_openai_key_here

# Anthropic API Key (可选)
ANTHROPIC_API_KEY=your_anthropic_key_here

# 本地模型 URL (可选)
LOCAL_MODEL_URL=http://localhost:11434

# 默认模型
DEFAULT_MODEL=gpt-3.5-turbo

# 缓存目录
CACHE_DIR=./cache

# 输出格式 (text, json, html)
OUTPUT_FORMAT=text

# 是否启用缓存
ENABLE_CACHE=true

# 诗歌模板
TEMPLATE=modern

# 批量处理并发数
BATCH_CONCURRENCY=5

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO